APP_NAME=PiOne Command Center
APP_VERSION=2.0.0
ENVIRONMENT=production
APP_TIMEZONE=America/Los_Angeles
LAB_HOSTNAME=PiOne

API_PORT=8000
WEB_PORT=3000
DATABASE_PATH=/data/pione-homepage.db
BACKUP_DIR=/backups

PUBLIC_BASE_URL=
TRUSTED_HOSTS=*
BEHIND_PROXY=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SESSION_COOKIE_SECURE=

AUTH_ENABLED=false
AUTH_ADMIN_USERNAME=admin
AUTH_SECRET_KEY=change-this-secret-key
AUTH_PASSWORD_HASH=
AUTH_PASSWORD=
AUTH_SESSION_TTL_HOURS=336

NAVIDROME_BASE_URL=
NAVIDROME_USERNAME=
NAVIDROME_PASSWORD=
NAVIDROME_TIMEOUT_SECONDS=4

DOCKER_SOCKET_PATH=/var/run/docker.sock
APP_CONTAINER_NAME=
SERVICE_MONITOR_TICK_SECONDS=20

CLOUDFLARED_TUNNEL_TOKEN=
